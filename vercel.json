{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/proyecto-pekin",
      "destination": "https://proyecto-pekin.kinku.com.co",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/:path((?!proyecto-pekin(?:/.*)?$).*)",
      "destination": "/index.html"
    }
  ]
}