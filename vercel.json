{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/proyecto-pekin/:match*",
      "destination": "https://darkseagreen-koala-884497.hostingersite.com/",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/:path((?!proyecto-pekin(?:/.*)?$).*)",
      "destination": "/index.html"
    }
  ]
}